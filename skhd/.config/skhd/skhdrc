:: default
:: service

# focus windows
default < alt - h : omniwmctl command focus left
default < alt - j : omniwmctl command focus down
default < alt - k : omniwmctl command focus up
default < alt - l : omniwmctl command focus right

# move windows
default < alt + shift - h : omniwmctl command move left
default < alt + shift - j : omniwmctl command move down
default < alt + shift - k : omniwmctl command move up
default < alt + shift - l : omniwmctl command move right

# punctuation keys use keycodes
# = 0x18
# - 0x1B
# ; 0x29
# , 0x2B
# / 0x2C

default < alt - 0x1B : omniwmctl command balance-sizes
# no direct OmniWM equivalent for yabai zoom-parent
# default < alt - 0x18 :

default < alt - 0x2C : omniwmctl command toggle-split
default < alt - 0x2B : omniwmctl command balance-sizes

# focus workspaces by display name: Z X C B M P O I Y T E W
default < alt - z : omniwmctl workspace focus-name Z
default < alt - x : omniwmctl workspace focus-name X
default < alt - c : omniwmctl workspace focus-name C
default < alt - b : omniwmctl workspace focus-name B
default < alt - m : omniwmctl workspace focus-name M
default < alt - p : omniwmctl workspace focus-name P
default < alt - o : omniwmctl workspace focus-name O
default < alt - i : omniwmctl workspace focus-name I
default < alt - y : omniwmctl workspace focus-name Y
default < alt - t : omniwmctl workspace focus-name T
default < alt - e : omniwmctl workspace focus-name E
default < alt - w : omniwmctl workspace focus-name W

# send window to workspace and follow it
default < alt + shift - z : omniwmctl command move-to-workspace 1  && omniwmctl workspace focus-name Z
default < alt + shift - x : omniwmctl command move-to-workspace 2  && omniwmctl workspace focus-name X
default < alt + shift - c : omniwmctl command move-to-workspace 3  && omniwmctl workspace focus-name C
default < alt + shift - b : omniwmctl command move-to-workspace 4  && omniwmctl workspace focus-name B
default < alt + shift - m : omniwmctl command move-to-workspace 5  && omniwmctl workspace focus-name M
default < alt + shift - p : omniwmctl command move-to-workspace 6  && omniwmctl workspace focus-name P
default < alt + shift - o : omniwmctl command move-to-workspace 7  && omniwmctl workspace focus-name O
default < alt + shift - i : omniwmctl command move-to-workspace 8  && omniwmctl workspace focus-name I
default < alt + shift - y : omniwmctl command move-to-workspace 9  && omniwmctl workspace focus-name Y
default < alt + shift - t : omniwmctl command move-to-workspace 10 && omniwmctl workspace focus-name T
default < alt + shift - e : omniwmctl command move-to-workspace 11 && omniwmctl workspace focus-name E
default < alt + shift - w : omniwmctl command move-to-workspace 12 && omniwmctl workspace focus-name W

default < alt - tab : omniwmctl command switch-workspace back-and-forth
default < alt - f : omniwmctl command toggle-fullscreen
default < alt + shift - space : omniwmctl command toggle-focused-window-floating
default < alt + shift - 0x29 ; service

# service mode
service < escape ; default
service < r : omniwmctl command balance-sizes
service < f : omniwmctl command toggle-focused-window-floating

# OmniWM has no separate directional "warp" action.
# Closest mapping is the same directional move command.
service < alt + shift - h : omniwmctl command move left
service < alt + shift - j : omniwmctl command move down
service < alt + shift - k : omniwmctl command move up
service < alt + shift - l : omniwmctl command move right

service < down : osascript -e 'set volume output volume ((output volume of (get volume settings)) - 6)'
service < up : osascript -e 'set volume output volume ((output volume of (get volume settings)) + 6)'
service < shift - down : osascript -e 'set volume output volume 0'